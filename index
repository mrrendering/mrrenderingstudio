<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MR Rendering — 3D Architectural Visualization</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --dark:#0a0a0a;
  --dark2:#111111;
  --dark3:#1a1a1a;
  --mid:#2a2a2a;
  --border:#2e2e2e;
  --gold:#c8a96e;
  --gold2:#e8c98e;
  --white:#f5f2ee;
  --muted:#888;
  --light:#ddd;
}
html{scroll-behavior:smooth}
body{
  background:var(--dark);
  color:var(--white);
  font-family:'Barlow',sans-serif;
  font-weight:300;
  overflow-x:hidden;
  line-height:1.6;
}
a{color:inherit;text-decoration:none}

/* NAV */
nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:20px 48px;
  background:rgba(10,10,10,0.85);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(200,169,110,0.1);
}
.nav-logo{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:600;font-size:22px;letter-spacing:3px;
  color:var(--white);
}
.nav-logo span{color:var(--gold)}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{
  font-size:12px;letter-spacing:2px;text-transform:uppercase;
  color:var(--muted);transition:color .3s;
}
.nav-links a:hover{color:var(--gold)}
.nav-cta{
  padding:10px 24px;
  border:1px solid var(--gold);
  font-size:11px;letter-spacing:2px;text-transform:uppercase;
  color:var(--gold);
  transition:all .3s;cursor:pointer;
  font-family:'Barlow',sans-serif;
}
.nav-cta:hover{background:var(--gold);color:var(--dark)}

/* HERO */
.hero{
  position:relative;min-height:100vh;
  display:flex;flex-direction:column;justify-content:center;
  padding:120px 48px 80px;
  overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    linear-gradient(135deg, rgba(200,169,110,0.04) 0%, transparent 50%),
    linear-gradient(to bottom, rgba(10,10,10,0) 60%, rgba(10,10,10,1) 100%);
  z-index:0;
}
.hero-grid-lines{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(200,169,110,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(200,169,110,0.05) 1px, transparent 1px);
  background-size:80px 80px;
  z-index:0;
}
.hero-content{position:relative;z-index:1;max-width:900px}
.hero-label{
  font-size:11px;letter-spacing:4px;text-transform:uppercase;
  color:var(--gold);margin-bottom:32px;
  display:flex;align-items:center;gap:16px;
}
.hero-label::before{content:'';width:40px;height:1px;background:var(--gold);display:block}
.hero-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(56px, 9vw, 120px);
  font-weight:300;line-height:0.95;
  letter-spacing:-2px;
  margin-bottom:8px;
}
.hero-title em{
  font-style:italic;color:var(--gold);
}
.hero-title .line2{
  font-family:'Barlow Condensed',sans-serif;
  font-weight:600;font-size:clamp(48px, 7.5vw, 100px);
  letter-spacing:4px;color:var(--light);
}
.hero-sub{
  font-size:15px;color:var(--muted);
  max-width:480px;line-height:1.8;
  margin:40px 0 56px;
}
.hero-actions{display:flex;gap:20px;align-items:center}
.btn-primary{
  padding:16px 40px;background:var(--gold);color:var(--dark);
  font-size:12px;letter-spacing:2px;text-transform:uppercase;
  font-weight:600;font-family:'Barlow',sans-serif;
  transition:all .3s;cursor:pointer;border:none;
  display:inline-block;
}
.btn-primary:hover{background:var(--gold2);transform:translateY(-2px)}
.btn-ghost{
  padding:16px 40px;border:1px solid rgba(255,255,255,0.2);
  font-size:12px;letter-spacing:2px;text-transform:uppercase;
  color:var(--light);transition:all .3s;cursor:pointer;
  display:inline-block;
}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold)}
.hero-stats{
  position:absolute;right:48px;bottom:80px;z-index:1;
  display:flex;flex-direction:column;gap:32px;align-items:flex-end;
}
.stat{text-align:right}
.stat-num{
  font-family:'Barlow Condensed',sans-serif;
  font-size:42px;font-weight:600;line-height:1;
  color:var(--white);
}
.stat-num span{color:var(--gold)}
.stat-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
.hero-scroll{
  position:absolute;bottom:40px;left:48px;z-index:1;
  display:flex;align-items:center;gap:16px;
  font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);
}
.scroll-line{width:60px;height:1px;background:rgba(200,169,110,0.4)}

/* MARQUEE */
.marquee-wrap{
  background:var(--gold);padding:14px 0;overflow:hidden;
  border-top:1px solid rgba(200,169,110,0.2);
}
.marquee-track{
  display:flex;gap:0;white-space:nowrap;
  animation:marquee 25s linear infinite;
}
.marquee-item{
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;letter-spacing:3px;text-transform:uppercase;
  color:var(--dark);font-weight:600;
  padding:0 32px;
}
.marquee-dot{color:rgba(10,10,10,0.3)}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* SECTION COMMON */
section{padding:100px 48px}
.section-label{
  font-size:11px;letter-spacing:4px;text-transform:uppercase;
  color:var(--gold);margin-bottom:16px;
  display:flex;align-items:center;gap:16px;
}
.section-label::before{content:'';width:24px;height:1px;background:var(--gold);display:block}
.section-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(36px,5vw,64px);font-weight:300;line-height:1.1;
  margin-bottom:16px;
}
.section-title em{font-style:italic;color:var(--gold)}

/* SERVICES */
.services{background:var(--dark2)}
.services-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
  margin-top:60px;background:var(--border);
}
.service-card{
  background:var(--dark2);padding:48px 36px;
  position:relative;overflow:hidden;
  transition:background .4s;
  display:block;
}
.service-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--gold);transform:scaleX(0);transform-origin:left;
  transition:transform .4s;
}
.service-card:hover{background:var(--dark3)}
.service-card:hover::before{transform:scaleX(1)}
.service-num{
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;letter-spacing:2px;color:var(--gold);
  margin-bottom:32px;opacity:0.7;
}
.service-icon{margin-bottom:24px}
.service-icon svg{width:36px;height:36px;stroke:var(--gold);fill:none;stroke-width:1}
.service-name{
  font-family:'Barlow Condensed',sans-serif;
  font-size:22px;font-weight:600;letter-spacing:1px;
  text-transform:uppercase;margin-bottom:16px;
  color:var(--white);
}
.service-desc{font-size:13px;color:var(--muted);line-height:1.8;margin-bottom:32px}
.service-link{
  font-size:11px;letter-spacing:2px;text-transform:uppercase;
  color:var(--gold);display:flex;align-items:center;gap:8px;
}
.service-link::after{content:'→';transition:transform .3s}
.service-card:hover .service-link::after{transform:translateX(6px)}

/* WHY US */
.why-us{background:var(--dark)}
.why-layout{display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-top:60px;align-items:start}
.why-visual{
  position:relative;background:var(--dark3);
  border:1px solid var(--border);
  padding:60px 48px;
}
.why-visual-accent{
  position:absolute;top:-1px;left:48px;width:80px;height:2px;background:var(--gold);
}
.why-big-num{
  font-family:'Cormorant Garamond',serif;
  font-size:140px;font-weight:300;line-height:1;
  color:rgba(200,169,110,0.1);letter-spacing:-8px;
  position:absolute;top:20px;right:20px;z-index:0;
}
.why-features{display:flex;flex-direction:column;gap:0}
.why-item{
  padding:32px 0;border-bottom:1px solid var(--border);
  display:flex;gap:24px;align-items:flex-start;
}
.why-item:first-child{padding-top:0}
.why-num{
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;color:var(--gold);letter-spacing:1px;
  min-width:28px;padding-top:4px;
}
.why-text h4{
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;font-weight:600;letter-spacing:1px;
  text-transform:uppercase;margin-bottom:8px;color:var(--white);
}
.why-text p{font-size:13px;color:var(--muted);line-height:1.8}

/* PORTFOLIO */
.portfolio{background:var(--dark2)}
.portfolio-intro{
  display:flex;justify-content:space-between;align-items:flex-end;
  margin-bottom:60px;
}
.portfolio-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  grid-template-rows:auto auto;
  gap:2px;
  background:var(--border);
}
.portfolio-item{
  background:var(--dark3);
  position:relative;overflow:hidden;
  display:flex;align-items:flex-end;
  min-height:300px;
  cursor:pointer;
}
.portfolio-item.large{grid-row:span 2;min-height:500px}
.portfolio-placeholder{
  position:absolute;inset:0;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:12px;
}
.portfolio-visual{
  width:100%;height:100%;
  background:linear-gradient(135deg, #1a1a1a 0%, #111 100%);
  position:relative;overflow:hidden;
}
.portfolio-visual::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(200,169,110,0.1) 0%,transparent 60%);
}
.arch-shape{
  position:absolute;bottom:0;left:50%;transform:translateX(-50%);
  width:60%;height:70%;
  border:1px solid rgba(200,169,110,0.15);
  border-bottom:none;
}
.arch-shape::after{
  content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);
  width:60%;height:80%;
  border:1px solid rgba(200,169,110,0.1);
  border-bottom:none;
}
.arch-window{
  position:absolute;top:10%;left:10%;right:10%;
  height:40%;background:rgba(200,169,110,0.05);
  border:1px solid rgba(200,169,110,0.1);
}
.portfolio-info{
  position:absolute;bottom:0;left:0;right:0;
  padding:24px 28px;
  background:linear-gradient(to top,rgba(10,10,10,0.95) 0%,transparent 100%);
  transform:translateY(60px);transition:transform .4s;
}
.portfolio-item:hover .portfolio-info{transform:translateY(0)}
.portfolio-cat{
  font-size:10px;letter-spacing:3px;text-transform:uppercase;
  color:var(--gold);margin-bottom:6px;
}
.portfolio-name{
  font-family:'Barlow Condensed',sans-serif;
  font-size:20px;font-weight:600;letter-spacing:1px;color:var(--white);
}
.portfolio-item:hover .portfolio-visual::after{
  background:linear-gradient(135deg,rgba(200,169,110,0.2) 0%,transparent 60%);
}

/* PROCESS */
.process{background:var(--dark)}
.process-steps{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:1px;background:var(--border);margin-top:60px;
}
.step{
  background:var(--dark);padding:40px 28px;
  position:relative;
}
.step-num{
  font-family:'Cormorant Garamond',serif;
  font-size:64px;font-weight:300;line-height:1;
  color:rgba(200,169,110,0.15);margin-bottom:24px;
}
.step-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:16px;font-weight:600;letter-spacing:2px;
  text-transform:uppercase;margin-bottom:12px;color:var(--white);
}
.step-desc{font-size:13px;color:var(--muted);line-height:1.8}
.step-line{
  position:absolute;top:40px;right:0;width:1px;height:40px;
  background:var(--gold);opacity:0.4;
}
.step:last-child .step-line{display:none}

/* SAVINGS */
.savings{
  background:var(--gold);
  padding:80px 48px;
  text-align:center;
}
.savings-num{
  font-family:'Cormorant Garamond',serif;
  font-size:120px;font-weight:300;line-height:1;
  color:var(--dark);letter-spacing:-4px;
}
.savings-label{
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;font-weight:600;letter-spacing:4px;
  text-transform:uppercase;color:var(--dark);
  margin-bottom:24px;
}
.savings-sub{font-size:15px;color:rgba(10,10,10,0.6);max-width:440px;margin:0 auto 40px}
.btn-dark{
  padding:16px 48px;background:var(--dark);color:var(--gold);
  font-size:12px;letter-spacing:2px;text-transform:uppercase;
  font-weight:600;font-family:'Barlow',sans-serif;
  transition:all .3s;display:inline-block;cursor:pointer;
}
.btn-dark:hover{background:var(--dark2)}

/* CONTACT */
.contact{background:var(--dark2)}
.contact-layout{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
.contact-info{padding-top:16px}
.contact-detail{margin-top:48px;display:flex;flex-direction:column;gap:24px}
.contact-row{display:flex;gap:16px;align-items:flex-start;padding-bottom:24px;border-bottom:1px solid var(--border)}
.contact-icon{
  width:36px;height:36px;border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.contact-icon svg{width:16px;height:16px;stroke:var(--gold);fill:none;stroke-width:1.5}
.contact-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.contact-val{font-size:14px;color:var(--white)}
.contact-form{background:var(--dark3);border:1px solid var(--border);padding:48px}
.form-row{margin-bottom:24px}
.form-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);display:block;margin-bottom:10px}
.form-input{
  width:100%;background:transparent;border:1px solid var(--border);
  padding:14px 16px;color:var(--white);font-family:'Barlow',sans-serif;
  font-size:14px;transition:border-color .3s;outline:none;
}
.form-input:focus{border-color:var(--gold)}
.form-input::placeholder{color:rgba(136,136,136,0.5)}
textarea.form-input{resize:vertical;min-height:100px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-submit{
  width:100%;padding:18px;background:var(--gold);color:var(--dark);
  font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:600;
  font-family:'Barlow',sans-serif;border:none;cursor:pointer;transition:background .3s;
}
.form-submit:hover{background:var(--gold2)}

/* FOOTER */
footer{
  background:var(--dark);border-top:1px solid var(--border);
  padding:60px 48px 40px;
}
.footer-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:48px}
.footer-logo{
  font-family:'Barlow Condensed',sans-serif;
  font-size:28px;font-weight:600;letter-spacing:4px;
}
.footer-logo span{color:var(--gold)}
.footer-tagline{font-size:12px;color:var(--muted);margin-top:8px;letter-spacing:1px}
.footer-links{display:grid;grid-template-columns:repeat(3,1fr);gap:40px}
.footer-col h5{
  font-size:11px;letter-spacing:3px;text-transform:uppercase;
  color:var(--gold);margin-bottom:20px;
}
.footer-col a{
  display:block;font-size:13px;color:var(--muted);
  margin-bottom:10px;transition:color .3s;
}
.footer-col a:hover{color:var(--white)}
.footer-bottom{
  border-top:1px solid var(--border);padding-top:32px;
  display:flex;justify-content:space-between;align-items:center;
}
.footer-copy{font-size:12px;color:rgba(136,136,136,0.5);letter-spacing:1px}
.social-links{display:flex;gap:16px}
.social-link{
  width:36px;height:36px;border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;color:var(--muted);transition:all .3s;letter-spacing:1px;
}
.social-link:hover{border-color:var(--gold);color:var(--gold)}

@media(max-width:900px){
  nav{padding:16px 24px}
  .nav-links{display:none}
  section{padding:60px 24px}
  .hero{padding:100px 24px 60px}
  .hero-stats{display:none}
  .services-grid{grid-template-columns:1fr}
  .why-layout,.contact-layout,.portfolio-intro{grid-template-columns:1fr;flex-direction:column}
  .portfolio-grid{grid-template-columns:1fr}
  .portfolio-item.large{grid-row:span 1}
  .process-steps{grid-template-columns:1fr 1fr}
  .footer-links{grid-template-columns:1fr}
  .footer-top{flex-direction:column;gap:32px}
  .form-grid{grid-template-columns:1fr}
}
</style>
</head>
